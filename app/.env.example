# ── Bridge API ───────────────────────────────────────────────────────────────
# During development, point at the mock server running on your Mac.
# On your home network, use the Pi's local IP, e.g. http://192.168.1.42:8080
BRIDGE_URL=http://localhost:3000

# ── Spotify ───────────────────────────────────────────────────────────────────
# 1. Go to https://developer.spotify.com/dashboard and create an app.
# 2. Under "Redirect URIs", add:  campfire://spotify-callback
# 3. Copy the Client ID here.
# NOTE: The Client ID is stored in-app via Settings; this file is for reference.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
